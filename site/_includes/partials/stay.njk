<div class="city-section">
  <div class="city-row">
    <div class="spine">
      <div class="cdot {{ stay.dotClass }}"></div>
      <div class="sline lstay" style="height:10px"></div>
    </div>
    <div class="ccard">
      <div class="ctitle">
        <span class="cname">{{ stay.city }}</span>
        <span class="cdates">{{ stay.dateRange }}</span>
      </div>
      <div class="chotel">{{ stay.hotel }}</div>
      {% if stay.locals | length %}
      <button class="local-btn" onclick="toggleLocal(this)"><span class="arr">▶</span> локальные перемещения</button>
      <div class="local-panel">
        <div class="local-inner">
          {% for tile in stay.locals %}
          {% include "partials/local-tile.njk" %}
          {% endfor %}
        </div>
      </div>
      {% endif %}
    </div>
  </div>
</div>
