<div class="leg-section">
  <div class="leg-row">
    <div class="lspine">
      <div class="llt ltravel"></div>
      <div class="liw {{ leg.iconWrapClass }}">
        {% if leg.iconKind == 'plane' %}
          <svg class="ic" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M17.8 19.2 16 11l3.5-3.5C21 6 21.5 4 21 3c-.9-.5-3 0-4.5 1.5L13 8 4.8 6.2c-.5-.1-.9.2-1.1.6l-1 2.5 6 3.1-3.6 3.6-2.6-.9c-.4-.1-.8.1-1 .5l-.5 1 3.5 2 2 3.5 1-.5c.4-.2.63.1 6l2.5-1c.4-.2.7-.6.6-1.1z"/></svg>
        {% else %}
          <svg class="ic" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="4" y="3" width="16" height="16" rx="2"/><path d="M4 11h16"/><path d="M12 3v8"/><path d="m8 19-2 3"/><path d="m16 19 2 3"/><path d="M8 15h0"/><path d="M16 15h0"/></svg>
        {% endif %}
      </div>
      <div class="llb ltravel"></div>
    </div>
    <div class="linfo">
      <div class="lmain">{{ leg.fromCity }} → {{ leg.toCity }}<span class="badge {{ leg.badgeClass }}">{{ leg.badgeIcon }}</span></div>
      <div class="lsub">{{ leg.depStr }} → {{ leg.arrStr }}</div>
    </div>
  </div>
</div>
