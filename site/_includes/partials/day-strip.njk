<div class="ds-wrap">
  <div class="ds-row" id="day-strip">
    {% for day in timeline.days %}
    <button class="ds-pill" data-date="{{ day.isoDate }}" onclick="selectDay('{{ day.isoDate }}')">
      <span class="ds-wd">{{ day.weekday }}</span>
      <span class="ds-num">{{ day.dayNum }}</span>
      <span class="ds-mo">{{ day.monthShort }}</span>
      <span class="ds-bar {{ day.dotClass }}"></span>
      {% if day.hasEvent %}<span class="ds-dot"></span>{% endif %}
    </button>
    {% endfor %}
  </div>

  <div class="ds-panel-area">
    {% for day in timeline.days %}
    <div class="ds-panel" id="day-{{ day.isoDate }}" hidden>
      <div class="ds-panel-head">
        <div class="ds-panel-date">
          <span class="ds-panel-tripday">День {{ day.tripDay }}</span>
          <span class="ds-panel-full">{{ day.dayNum }} {{ day.monthFull }}, {{ day.weekdayFull }}</span>
        </div>
        {% if day.city %}
        <span class="ds-panel-city">
          <span class="ds-city-dot {{ day.dotClass }}"></span>{{ day.city }}
        </span>
        {% endif %}
      </div>
      {% if day.events | length %}
      <div class="ds-events">
        {% for ev in day.events %}
        <div class="ds-ev">
          <span class="ds-ev-icon {% if ev.iconKind == 'plane' %}ip{% elif ev.iconKind == 'train' %}itr{% elif ev.iconKind == 'hotel-in' or ev.iconKind == 'hotel-out' %}ihot{% else %}ifa{% endif %}">
            {% if ev.iconKind == 'plane' %}
              <svg class="ic" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M17.8 19.2 16 11l3.5-3.5C21 6 21.5 4 21 3c-.9-.5-3 0-4.5 1.5L13 8 4.8 6.2c-.5-.1-.9.2-1.1.6l-1 2.5 6 3.1-3.6 3.6-2.6-.9c-.4-.1-.8.1-1 .5l-.5 1 3.5 2 2 3.5 1-.5c.4-.2.63.1 6l2.5-1c.4-.2.7-.6.6-1.1z"/></svg>
            {% elif ev.iconKind == 'train' %}
              <svg class="ic" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="4" y="3" width="16" height="16" rx="2"/><path d="M4 11h16"/><path d="M12 3v8"/><path d="m8 19-2 3"/><path d="m16 19 2 3"/><path d="M8 15h0"/><path d="M16 15h0"/></svg>
            {% elif ev.iconKind == 'hotel-in' %}
              <svg class="ic" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M15 14v4"/><path d="M9 14v4"/><path d="M3 21h18"/><path d="M5 21V5a2 2 0 0 1 2-2h10a2 2 0 0 1 2 2v16"/></svg>
            {% elif ev.iconKind == 'hotel-out' %}
              <svg class="ic" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M9 21V5a2 2 0 0 1 2-2h8a2 2 0 0 1 2 2v16"/><path d="M21 21H3"/><path d="M14 10v4"/><path d="M3 14h6l-2-2"/><path d="m7 16-2-2"/></svg>
            {% else %}
              <svg class="ic" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20 10c0 6-8 12-8 12s-8-6-8-12a8 8 0 0 1 16 0Z"/><circle cx="12" cy="10" r="3"/></svg>
            {% endif %}
          </span>
          <span class="ds-ev-text">{{ ev.text }}</span>
        </div>
        {% endfor %}
      </div>
      {% else %}
      <div class="ds-empty">Свободный день{% if day.city %} · {{ day.city }}{% endif %}</div>
      {% endif %}
    </div>
    {% endfor %}
  </div>
</div>
